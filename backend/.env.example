# ==============================
# Tracklet Backend — Environment
# ==============================
# Copy this file to .env and fill in your values.

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# --- Security ---
# Generate a strong random string for this (e.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-very-strong-secret-key-here

# --- Scraper ---
# true  = Use mock scraper (fake prices, no Puppeteer, no IP blocks)
# false = Use real Puppeteer scraper (needs Chrome installed)
USE_MOCK_SCRAPER=true

# --- Email ---
# true  = Send real emails via Gmail SMTP
# false = Skip email sending (log only)
SEND_EMAILS=false
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# --- Local Development ---
PORT=3000
# true = Enable local cron job (every 5 min)
ENABLE_LOCAL_CRON=false
